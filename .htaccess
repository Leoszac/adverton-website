# Adverton — Apache rewrite rules for clean URLs

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Strip .html from URL: /hvac.html → /hvac (preserves SEO canonical)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Magic-link public forms: clean URLs that map to .php files (no .html exists).
# Each one is registered explicitly so the generic .html rewriter below stays
# untouched and can't accidentally serve the wrong file.
RewriteRule ^pre-contract/?$ pre-contract.php [L]
RewriteRule ^kickoff/?$      kickoff.php      [L]
RewriteRule ^preview/(\d+)/?$ preview.php?id=$1 [L,QSA]

# Internally route /hvac → /hvac.html (so the file actually loads)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^.]+)$ $1.html [L]

# Cache static assets aggressively
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Compress text-based responses
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml image/svg+xml
</IfModule>

# Block direct access to dotfiles — return 404 (not 403) so Google doesn't flag them
<FilesMatch "^\.">
  Require all denied
  ErrorDocument 403 /404.html
</FilesMatch>

# Belt-and-suspenders: block any *-config*.php and *.example.php from web access.
# Real audit secrets live outside public_html; this ensures the example template
# can't be loaded if it ever leaks into the deploy.
<FilesMatch "(^|.*-)config(\.|-).*\.php$|\.example\.php$">
  Require all denied
</FilesMatch>

# email-pipe.php is invoked by cPanel's mail forwarder (CLI/exec, NOT web).
# It needs chmod 755 so the kernel will exec it via shebang — but Apache then
# tries to serve it as CGI on direct HTTP hits, which 500s. Block web access
# entirely. Forwarder pipe still works (it doesn't go through Apache).
<Files "email-pipe.php">
  Require all denied
</Files>

# Real 404 page (returns proper 404 status, no soft-404 redirect to /)
ErrorDocument 404 /404.html

# Set canonical via header for query-stringed homepage requests (helps GSC)
<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set X-Robots-Tag "index, follow"
  </FilesMatch>
</IfModule>
